# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one is required. The active provider is set via the /dashboard UI.
GOOGLE_API_KEY=your_google_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # optional
ANTHROPIC_API_KEY=your_anthropic_api_key_here    # optional

# ── Flask ──────────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string-in-production

# 'development' or 'production'
# production enables SESSION_COOKIE_SECURE (HTTPS-only cookies)
FLASK_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, fine for local dev):
DATABASE_URL=sqlite:///production.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/medbot

# ── Redis (optional) ───────────────────────────────────────────────────────────
# Used by Flask-Limiter in production. Falls back to in-memory if not set.
# REDIS_URL=redis://localhost:6379/0
